IYZICO_COUNTRY=Turkey
IYZICO_ZIP=34000

# Optional mail delivery of Pro token
AUTO_EMAIL_TOKEN_ON_PAYMENT=1
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
