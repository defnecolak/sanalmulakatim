ABOUT_LONG=

# Core secrets
OPENAI_API_KEY=
ADMIN_STATUS_KEY=
CLIENT_ID_SALT=
EMAIL_HASH_SALT=
RECOVERY_TOKEN_SECRET=
SESSION_SECRET=
DELETE_TOKEN_SECRET=

# Host / origin hardening
ALLOWED_HOSTS=ornek-domain.com,www.ornek-domain.com
ALLOWED_ORIGINS=https://ornek-domain.com,https://www.ornek-domain.com
TRUST_PROXY_HEADERS=1
REQUIRE_ORIGIN=1
SECURITY_HEADERS=1
HSTS=1
ENABLE_API_DOCS=0

# Payment - iyzico live or sandbox
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com
IYZICO_TIMEOUT=25
IYZICO_VALIDATE_SIGNATURE=1

# Buyer fallback fields (replace with real collected buyer info in production)
IYZICO_BUYER_NAME=
IYZICO_BUYER_SURNAME=
IYZICO_IDENTITY_NUMBER=
IYZICO_GSM_NUMBER=
IYZICO_FALLBACK_EMAIL=
