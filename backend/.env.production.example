# Production template
APP_NAME=Sanal Mülakatım
SUPPORT_EMAIL=
PUBLIC_BASE_URL=https://ornek-domain.com
PAYMENT_PROVIDER=iyzico
PRO_PRICE_TRY=199.0
PRO_TITLE=Pro Erişim

# Company / compliance fields shown on landing, about and contact pages
BUSINESS_LEGAL_NAME=
BUSINESS_TRADE_NAME=
BUSINESS_MERSIS_NUMBER=
BUSINESS_TAX_NUMBER=
BUSINESS_ADDRESS=
BUSINESS_KEP_ADDRESS=
BUSINESS_PHONE=
BUSINESS_CHAMBER=
